    
{% assign s = section.settings %}
{% assign eye_id = 'joydot-' | append: section.id %}
{% assign ellipse_cx = s.ellipse_cx %}
{% assign ellipse_cy = s.ellipse_cy %}
{% assign ellipse_rx = s.ellipse_rx %}
{% assign circle_cy = s.circle_cy %}
{% assign filter_0_blur = s.filter_0_blur %}
{% assign filter_1_blur = s.filter_1_blur %}
{% assign eye_sensitivity = s.eye_sensitivity | divided_by: 10.0 %}

{% assign glow_pad = filter_0_blur | times: 3 | plus: 24 %}
{% assign circle_pad = filter_1_blur | times: 3 | plus: 24 %}
{% assign auto_min_y = ellipse_cy | minus: s.ellipse_ry | minus: glow_pad %}
{% assign circle_min_y = circle_cy | minus: s.circle_r | minus: circle_pad %}
{% if circle_min_y < auto_min_y %}
  {% assign auto_min_y = circle_min_y %}
{% endif %}
{% assign viewbox_min_y = auto_min_y %}
{% if s.viewbox_min_y < viewbox_min_y %}
  {% assign viewbox_min_y = s.viewbox_min_y %}
{% endif %}
{% assign circle_top_y = circle_cy | minus: s.circle_r %}
{% assign visible_height = s.circle_r | times: 2 | times: s.visible_percent | divided_by: 100 %}
{% assign viewbox_max_y = circle_top_y | plus: visible_height %}
{% assign viewbox_height = viewbox_max_y | minus: viewbox_min_y %}

{% assign filter_0_auto_x = ellipse_cx | minus: ellipse_rx | minus: glow_pad %}
{% assign filter_0_auto_y = ellipse_cy | minus: s.ellipse_ry | minus: glow_pad %}
{% assign filter_0_auto_width = ellipse_rx | times: 2 | plus: glow_pad | times: 2 %}
{% assign filter_0_auto_height = s.ellipse_ry | times: 2 | plus: glow_pad | times: 2 %}
{% assign filter_0_x = filter_0_auto_x %}
{% if s.filter_0_x < filter_0_x %}
  {% assign filter_0_x = s.filter_0_x %}
{% endif %}
{% assign filter_0_y = filter_0_auto_y %}
{% if s.filter_0_y < filter_0_y %}
  {% assign filter_0_y = s.filter_0_y %}
{% endif %}
{% assign filter_0_width = filter_0_auto_width %}
{% if s.filter_0_width > filter_0_width %}
  {% assign filter_0_width = s.filter_0_width %}
{% endif %}
{% assign filter_0_height = filter_0_auto_height %}
{% if s.filter_0_height > filter_0_height %}
  {% assign filter_0_height = s.filter_0_height %}
{% endif %}

{% assign filter_1_auto_x = s.circle_cx | minus: s.circle_r | minus: circle_pad %}
{% assign filter_1_auto_y = circle_cy | minus: s.circle_r | minus: circle_pad %}
{% assign filter_1_auto_width = s.circle_r | times: 2 | plus: circle_pad | times: 2 %}
{% assign filter_1_auto_height = s.circle_r | times: 2 | plus: circle_pad | times: 2 %}
{% assign filter_1_x = filter_1_auto_x %}
{% if s.filter_1_x < filter_1_x %}
  {% assign filter_1_x = s.filter_1_x %}
{% endif %}
{% assign filter_1_y = filter_1_auto_y %}
{% if s.filter_1_y < filter_1_y %}
  {% assign filter_1_y = s.filter_1_y %}
{% endif %}
{% assign filter_1_width = filter_1_auto_width %}
{% if s.filter_1_width > filter_1_width %}
  {% assign filter_1_width = s.filter_1_width %}
{% endif %}
{% assign filter_1_height = filter_1_auto_height %}
{% if s.filter_1_height > filter_1_height %}
  {% assign filter_1_height = s.filter_1_height %}
{% endif %}

<div
  class="joydot-wrapper"
  id="{{ eye_id }}"
  {% if s.enable_blink %}
    data-enable-blink="true"
  {% endif %}
  style="aspect-ratio: {{ s.viewbox_width }} / {{ viewbox_height }};{% if s.enable_blink %} --joydot-blink-interval: {{ s.blink_interval }}s;{% endif %}"
>
  <svg
    width="{{ s.viewbox_width }}"
    height="{{ viewbox_height }}"
    viewBox="{{ s.viewbox_min_x }} {{ viewbox_min_y }} {{ s.viewbox_width }} {{ viewbox_height }}"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    <g filter="url(#{{ eye_id }}-f0)">
      <ellipse cx="{{ ellipse_cx }}" cy="{{ ellipse_cy }}" rx="{{ ellipse_rx }}" ry="{{ s.ellipse_ry }}" fill="{{ s.ellipse_color }}"/>
    </g>
    <g filter="url(#{{ eye_id }}-f1)">
      <circle cx="{{ s.circle_cx }}" cy="{{ circle_cy }}" r="{{ s.circle_r }}" fill="url(#{{ eye_id }}-grad)"/>
    </g>
    <g id="{{ eye_id }}-left" class="joydot-eye__track">
      <g class="joydot-eye">
        <path d="M521.143 269.356C521.508 266.964 522.692 266.964 523.058 269.356C525.594 285.961 533.372 308.782 556.126 322.399C577.419 335.143 630.472 346.888 647.087 350.356C648.818 350.717 648.818 352.056 647.087 352.417C630.472 355.886 577.419 367.631 556.126 380.374C533.372 393.992 525.594 416.812 523.058 433.418C522.692 435.81 521.508 435.81 521.143 433.418C518.607 416.812 510.829 393.992 488.074 380.374C466.77 367.625 415.33 355.874 399.277 352.412C397.574 352.045 397.574 350.728 399.277 350.361C415.33 346.9 466.77 335.149 488.074 322.399C510.829 308.782 518.607 285.962 521.143 269.356Z" fill="{{ s.eye_color }}"/>
      </g>
    </g>
    <g id="{{ eye_id }}-right" class="joydot-eye__track">
      <g class="joydot-eye">
        <path d="M897.758 278.383C898.123 275.991 899.308 275.991 899.673 278.383C902.209 294.989 909.987 317.809 932.741 331.427C954.035 344.17 1007.09 355.915 1023.7 359.383C1025.43 359.745 1025.43 361.083 1023.7 361.445C1007.09 364.913 954.035 376.658 932.741 389.402C909.987 403.019 902.209 425.839 899.673 442.445C899.308 444.837 898.123 444.837 897.758 442.445C895.222 425.839 887.444 403.019 864.689 389.402C843.385 376.652 791.945 364.901 775.892 361.44C774.189 361.072 774.189 359.756 775.892 359.388C791.945 355.927 843.385 344.176 864.689 331.427C887.444 317.809 895.222 294.989 897.758 278.383Z" fill="{{ s.eye_color }}"/>
      </g>
    </g>
    <defs>
      <filter id="{{ eye_id }}-f0" x="{{ filter_0_x }}" y="{{ filter_0_y }}" width="{{ filter_0_width }}" height="{{ filter_0_height }}" filterUnits="userSpaceOnUse" color-interpolation-filters="sRGB">
        <feFlood flood-opacity="0" result="BackgroundImageFix"/>
        <feBlend mode="normal" in="SourceGraphic" in2="BackgroundImageFix" result="shape"/>
        <feGaussianBlur stdDeviation="{{ filter_0_blur }}" result="effect1_foregroundBlur"/>
      </filter>
      <filter id="{{ eye_id }}-f1" x="{{ filter_1_x }}" y="{{ filter_1_y }}" width="{{ filter_1_width }}" height="{{ filter_1_height }}" filterUnits="userSpaceOnUse" color-interpolation-filters="sRGB">
        <feFlood flood-opacity="0" result="BackgroundImageFix"/>
        <feBlend mode="normal" in="SourceGraphic" in2="BackgroundImageFix" result="shape"/>
        <feGaussianBlur stdDeviation="{{ filter_1_blur }}" result="effect1_foregroundBlur"/>
      </filter>
      <radialGradient id="{{ eye_id }}-grad" cx="0" cy="0" r="1" gradientUnits="userSpaceOnUse" gradientTransform="translate({{ s.circle_cx }} {{ circle_cy }}) rotate(90) scale({{ s.circle_r }})">
        <stop stop-color="{{ s.gradient_inner }}"/>
        <stop offset="1" stop-color="{{ s.gradient_outer }}"/>
      </radialGradient>
    </defs>
  </svg>
</div>

<script>
  (function() {
    var wrapper = document.getElementById('{{ eye_id }}');
    if (!wrapper) return;

    var svg = wrapper.querySelector('svg');
    var leftStar = document.getElementById('{{ eye_id }}-left');
    var rightStar = document.getElementById('{{ eye_id }}-right');
    var maxTravel = {{ s.eye_travel }};
    var eyeSensitivity = {{ eye_sensitivity }};

    var viewBoxWidth = {{ s.viewbox_width }};
    var viewBoxHeight = {{ viewbox_height }};
    var viewBoxMinX = {{ s.viewbox_min_x }};
    var viewBoxMinY = {{ viewbox_min_y }};
    var circleCenterX = {{ s.circle_cx }};
    var equatorY = {{ circle_cy }};

    function trackCursor(e) {
      var svgRect = svg.getBoundingClientRect();
      var scaleX = svgRect.width / viewBoxWidth;
      var scaleY = svgRect.height / viewBoxHeight;

      var cx = svgRect.left + (circleCenterX - viewBoxMinX) * scaleX;
      var cy = svgRect.top + (equatorY - viewBoxMinY) * scaleY;
      var angle = Math.atan2(e.clientY - cy, e.clientX - cx);
      var raw = Math.hypot(e.clientX - cx, e.clientY - cy) * eyeSensitivity;
      var dist = Math.min(maxTravel, raw);
      var dx = Math.cos(angle) * dist / scaleX;
      var dy = Math.sin(angle) * dist / scaleY;
      var transform = 'translate(' + dx + ',' + dy + ')';
      leftStar.setAttribute('transform', transform);
      rightStar.setAttribute('transform', transform);
    }

    document.addEventListener('mousemove', trackCursor);
  })();
</script>

{% stylesheet %}
  .joydot-wrapper {
    width: 100%;
    overflow: hidden;
    line-height: 0;
  }

  .joydot-wrapper svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .joydot-eye {
    transform-box: fill-box;
    transform-origin: center;
  }

  @keyframes joydot-blink {
    0%,
    96%,
    100% {
      transform: scaleY(1);
    }

    97.5% {
      transform: scaleY(0.06);
    }
  }

  .joydot-wrapper[data-enable-blink='true'] .joydot-eye {
    animation: joydot-blink var(--joydot-blink-interval, 5s) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .joydot-wrapper[data-enable-blink='true'] .joydot-eye {
      animation: none;
    }
  }
{% endstylesheet %}

