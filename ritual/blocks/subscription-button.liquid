{% assign block_settings = block.settings %}
{% liquid
  assign button_style = block_settings.button_style | default: 'button'
  assign menu_color_class = ''

  if block_settings.menu_use_theme_popover
    assign menu_color_class = 'color-' | append: settings.popover_color_scheme
  elsif block_settings.menu_inherit_color_scheme == false
    assign menu_color_class = 'color-' | append: block_settings.menu_color_scheme
  endif
%}
<div
  class="subscription-dropdown{% if block_settings.inherit_color_scheme == false %} color-{{ block_settings.color_scheme }} background-transparent{% endif %}"
  data-subscription-dropdown
  {{ block.shopify_attributes }}
>
  <button
    type="button"
    class="{{ button_style }} subscription-dropdown__toggle"
    aria-expanded="false"
    aria-haspopup="listbox"
    data-subscription-toggle
  >
    <span data-subscription-label>{{ block_settings.button_label | default: 'Subscribe & save 15%' }}</span>
    <span class="subscription-dropdown__chevron" aria-hidden="true">▾</span>
  </button>
  <ul
    class="subscription-dropdown__menu{% if menu_color_class != blank %} {{ menu_color_class }}{% endif %}"
    role="listbox"
    hidden
    data-subscription-menu
  >
    <li role="option" data-label="One-time purchase" tabindex="-1">One-time purchase</li>
    <li role="option" data-label="Subscribe & save 15%" tabindex="-1">Subscribe & save 15%</li>
  </ul>
</div>
{% stylesheet %}
  .subscription-dropdown {
    position: relative;
    width: 100%;
  }

  .subscription-dropdown--open {
    z-index: var(--layer-raised);
  }

  /* Product details group-block gets overflow:hidden from border-override; allow menu to escape */
  .product-details .group-block:has(.subscription-dropdown--open),
  .product-details .group-block-content:has(.subscription-dropdown--open) {
    overflow: visible !important;
  }

  .subscription-dropdown.background-transparent {
    background-color: transparent;
  }

  .subscription-dropdown__toggle {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .subscription-dropdown__toggle:focus-visible {
    outline: none;
    box-shadow:
      inset 0 0 0 var(--focus-outline-width) var(--color-foreground),
      inset 0 0 0 var(--button-border-width) var(--button-border-color);
  }

  .subscription-dropdown__chevron {
    font-size: 0.875rem;
    line-height: 1;
    transition: transform var(--animation-speed) var(--animation-easing);
  }

  .subscription-dropdown--open .subscription-dropdown__chevron {
    transform: rotate(180deg);
  }

  .subscription-dropdown__menu {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 8px);
    z-index: var(--layer-raised);
    margin: 0;
    padding: calc(var(--padding-xs, 8px) / 2);
    list-style: none;
    color: var(--color-foreground);
    background-color: var(--color-background);
    border: var(--style-border-popover);
    border-radius: var(--style-border-radius-popover);
    box-shadow: var(--shadow-popover, 0 8px 24px rgb(var(--color-shadow-rgb) / 0.12));
  }

  .subscription-dropdown__menu[hidden] {
    display: none;
  }

  .subscription-dropdown__menu li {
    padding: var(--padding-2xs, 8px) var(--padding-sm, 12px);
    border-radius: calc(var(--style-border-radius-popover) / 2);
    cursor: pointer;
    transition: background-color var(--animation-speed) var(--animation-easing);
  }

  .subscription-dropdown__menu li:hover,
  .subscription-dropdown__menu li:focus-visible {
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-8, 0.08));
    outline: none;
  }

  .subscription-dropdown__menu li[aria-selected='true'] {
    font-weight: 500;
    background-color: rgb(var(--color-foreground-rgb) / var(--opacity-8, 0.08));
  }
{% endstylesheet %}
{% javascript %}
  document.querySelectorAll('[data-subscription-toggle]').forEach((toggle) => {
    const wrapper = toggle.closest('.subscription-dropdown');
    const menu = wrapper.querySelector('[data-subscription-menu]');
    const label = wrapper.querySelector('[data-subscription-label]');

    const syncSelectedOption = () => {
      menu.querySelectorAll('[role="option"]').forEach((option) => {
        const isSelected = option.dataset.label === label.textContent.trim();
        option.setAttribute('aria-selected', String(isSelected));
      });
    };

    const setOpen = (isOpen) => {
      menu.hidden = !isOpen;
      toggle.setAttribute('aria-expanded', String(isOpen));
      wrapper.classList.toggle('subscription-dropdown--open', isOpen);
    };

    syncSelectedOption();

    toggle.addEventListener('click', (event) => {
      event.stopPropagation();
      const willOpen = menu.hidden;
      setOpen(willOpen);
      if (willOpen) {
        syncSelectedOption();
      }
    });

    menu.querySelectorAll('[role="option"]').forEach((option) => {
      option.addEventListener('click', () => {
        label.textContent = option.dataset.label;
        setOpen(false);
        syncSelectedOption();
      });
    });

    document.addEventListener('click', (event) => {
      if (!wrapper.contains(event.target)) {
        setOpen(false);
      }
    });
  });
{% endjavascript %}
{% schema %}
{
  "name": "Subscription dropdown",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe & save 15%"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "t:content.appearance"
    },
    {
      "type": "checkbox",
      "id": "inherit_color_scheme",
      "label": "t:settings.inherit_color_scheme",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-3",
      "visible_if": "{{ block.settings.inherit_color_scheme == false }}"
    },
    {
      "type": "header",
      "content": "Menu"
    },
    {
      "type": "checkbox",
      "id": "menu_use_theme_popover",
      "label": "Use theme popover colors",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "menu_inherit_color_scheme",
      "label": "Inherit menu colors",
      "default": true,
      "visible_if": "{{ block.settings.menu_use_theme_popover == false }}"
    },
    {
      "type": "color_scheme",
      "id": "menu_color_scheme",
      "label": "Menu color scheme",
      "default": "scheme-3",
      "visible_if": "{{ block.settings.menu_use_theme_popover == false and block.settings.menu_inherit_color_scheme == false }}"
    }
  ],
  "presets": [
    {
      "name": "Subscription dropdown",
      "category": "t:categories.product"
    }
  ]
}
{% endschema %}
