{% comment %}
  Extracted from instant-M240HYHEV8IUsSdn.liquid — shared navigation bar.
  Maintained separately so Instant re-exports do not duplicate the header.
{% endcomment %}
<div
  class="__instant iM240HYHEV8IUsSdn instant-header-section"
  data-instant-id="M240HYHEV8IUsSdn-header"
  data-instant-version="4.6.3"
  data-instant-layout="SECTION"
  data-section-id="{{ section.id }}"
>
  {%- style -%}
    .__instant[data-section-id='{{ section.id }}'] .instant-header-root {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    @media screen and (min-width: 769px) {
      .__instant[data-section-id='{{ section.id }}'] .instant-header-root {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }

    .__instant[data-section-id='{{ section.id }}'] .instant-header {
      background: #fff8e5;
      margin: 0 auto;
      max-width: 1440px;
      min-height: 183px;
      overflow: hidden;
      position: relative;
      width: 100%;
    }
  {%- endstyle -%}
  {{ 'instant-M240HYHEV8IUsSdn.css' | asset_url | stylesheet_tag: preload: true -}}
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@800&amp;family=IBM+Plex+Mono:wght@700&amp;family=Montserrat:wght@500;700&amp;display=swap"
    rel="stylesheet"
  >
  <div data-instant-type="root" class="instant-header-root iPSSFqkUqW1LHcvKV">
    <div class="instant-header" data-instant-type="container">
      <div class="iSfLtEkjseUNiiGJL-5TaxzTcNOMu5pKsk" data-instant-type="container">
        {%- if section.settings.header_bar != blank -%}
          {{ section.settings.header_bar | image_url: width: 1440 | image_tag: class: 'instant-fill instant-image__fill', alt: section.settings.header_bar.alt, fetchpriority: 'high', loading: 'eager', decoding: 'async' }}
        {%- else -%}
          <img
            alt=""
            src="https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/zih88DIzhOs1FLVT/3da54177d2682a5a1c65e599e9d1c25db5f7b9e5.svg"
            width="1440"
            height="183"
            class="instant-fill instant-image__fill"
            decoding="async"
            fetchpriority="high"
            loading="eager"
            style="object-fit:cover"
          >
        {%- endif -%}
      </div>
      <div class="ir3pkb2tkrQ7yoJnt" data-instant-type="container">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 1280 | image_tag: class: 'instant-fill instant-image__fill', alt: section.settings.logo.alt, fetchpriority: 'high', loading: 'eager', decoding: 'async' }}
        {%- else -%}
          <img
            alt=""
            sizes="(max-width: 1280px) 100vw, 1280px"
            srcset="https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=1080 1080w, https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=828 828w, https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=750 750w, https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=640 640w, https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=360 360w, https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=1280 1280w"
            src="https://cdn.instant.so/sites/tSNy8fAu9E1hsw1G/assets/cGYAtiAMbI5Bqdvg/629dfbd0199b7b7c8e9565bbf7ab2a0b43bcca05.png?width=1280"
            width="458"
            height="104"
            class="instant-fill instant-image__fill"
            decoding="async"
            fetchpriority="high"
            loading="eager"
            style="object-fit:cover"
          >
        {%- endif -%}
      </div>
      <div data-instant-type="text" class="instant-rich-text iyZD93ikxhxMRJqOS">
        <div>{{ section.settings.nav_link_1 }}</div>
      </div>
      <div data-instant-type="text" class="instant-rich-text iQT7tRyB4kpTgiJW0">
        <div>{{ section.settings.nav_link_2 }}</div>
      </div>
      <div data-instant-type="text" class="instant-rich-text i0463kmWfUsvc8831">
        <div>{{ section.settings.nav_link_3 }}</div>
      </div>
      <div data-instant-type="text" class="instant-rich-text iIEGxPvPe3VahhiKa">
        <div>{{ section.settings.nav_link_4 }}</div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Instant header",
  "tag": "section",
  "class": "instant-header-wrapper",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "header_bar",
      "label": "Header bar decoration"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "richtext",
      "id": "nav_link_1",
      "label": "Nav link 1",
      "default": "<p>home</p>"
    },
    {
      "type": "richtext",
      "id": "nav_link_2",
      "label": "Nav link 2",
      "default": "<p>product</p>"
    },
    {
      "type": "richtext",
      "id": "nav_link_3",
      "label": "Nav link 3",
      "default": "<p>home</p>"
    },
    {
      "type": "richtext",
      "id": "nav_link_4",
      "label": "Nav link 4",
      "default": "<p>home</p>"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Instant header",
      "settings": {
        "nav_link_1": "<p>home</p>",
        "nav_link_2": "<p>product</p>",
        "nav_link_3": "<p>home</p>",
        "nav_link_4": "<p>home</p>"
      }
    }
  ]
}
{% endschema %}
