// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model EmailSubscriber {
  id        String   @id @default(uuid())
  email     String   @unique
  source    String   @default("newsletter")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  newsletterOptIn Boolean   @default(false)
  createdAt       DateTime  @default(now())

  addresses Address[]
  orders    Order[]

  @@index([email])
}

model Address {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  line1       String
  line2       String?
  city        String
  state       String
  postal_code String
  country     String   @default("US")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  orders Order[]

  @@index([userId])
}

enum OrderStatus {
  PENDING    // payment initiated
  PAID       // payment confirmed — awaiting shipment
  SHIPPED    // handed to carrier
  DELIVERED  // confirmed delivered
  FAILED     // payment failed
  CANCELLED  // cancelled before shipment
  REFUNDED   // refunded after payment
}

model Order {
  id              String      @id @default(uuid())
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  addressId       String
  address         Address     @relation(fields: [addressId], references: [id], onDelete: Restrict)
  status          OrderStatus @default(PENDING)
  stripeSessionId String      @unique
  total           Int         // cents
  createdAt       DateTime    @default(now())

  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?

  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id              String  @id @default(uuid())
  orderId         String
  order           Order   @relation(fields: [orderId], references: [id])
  productId       String  // matches id in products.ts
  name            String  // snapshot at purchase time
  priceAtPurchase Int     // cents — snapshot at purchase time
  quantity        Int
  imageUrl        String?

  @@index([orderId])
}

