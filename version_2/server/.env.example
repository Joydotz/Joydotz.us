# Node environment: development | test | production
NODE_ENV=development

# Port the backend listens on
PORT=3001

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/joydotz

# PostgreSQL connection string used only during tests (MUST NOT duplicate DATABASE_URL)
TEST_DATABASE_URL=postgresql://joydotz:joydotz@localhost:5434/joydotz_test

# Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=change-this-to-a-long-random-secret-before-deploying
# Public URL of this API (used for auth callbacks and cookies)
BETTER_AUTH_URL=http://localhost:3001

# Stripe secret key (never the publishable key)
STRIPE_SECRET_KEY=sk_test_...

# Stripe stripe event signing secret (set when stripe event endpoint is registered)
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: force Stripe readiness check before create-session (prices + webhook secret + endpoint list).
# Default on when NODE_ENV=development; set to 0 to skip in dev. Set to 1 to enable in other environments.
# STRIPE_CHECKOUT_READINESS=1

# Allowed frontend origin for CORS — no trailing slash
FRONTEND_ORIGIN=http://localhost:5173

# Email API key for sending transactional emails (Resend, SendGrid, Postmark, etc.)
EMAIL_API_KEY=your_email_api_key_here

# The domain that will be used to send emails from
EMAIL_DOMAIN=yourdomain.com
